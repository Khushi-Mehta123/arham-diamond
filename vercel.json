{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "services": {
        "frontend": {
            "root": "frontend",
            "framework": "vite",
            "entrypoint": "dist/index.html"
        },
        "backend": {
            "root": "backend",
            "entrypoint": "src/index.ts"
        }
    },
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": {
                "type": "service",
                "service": "backend"
            }
        },
        {
            "source": "/(.*)",
            "destination": {
                "type": "service",
                "service": "frontend"
            }
        }
    ]
}
